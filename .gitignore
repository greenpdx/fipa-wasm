target/
Cargo.lock
node_modules

# Downloaded WordNet 3.1 database (fetched by `cargo run -p xtask -- fetch-wordnet`;
# redistributed separately under the WordNet licence, not vendored in git).
/data/kb-seed/wordnet-3.1/

# Downloaded AESOP UNL corpus (fetched by `cargo run -p xtask -- fetch-aesop`).
# No explicit open licence (UNDL Foundation terms), so fetched on demand, not vendored.
/data/corpus/

# Compiled embedded KB (built by `cargo run -p xtask -- build-kb` from the WordNet seed).
/data/kb-seed/unl-kb.sled/
